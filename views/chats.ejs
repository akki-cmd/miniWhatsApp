<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home </title>
    <link href="style.css" rel="stylesheet">
</head>
<body>
    <h1> All Chats !!</h1>

    <div class="container">
        <% for(let chat of chats){ %>
            <div class="chat">
                <h3>From:   <h4><%= chat.from %> </h4>   <h3>To:</h3> <h4><%= chat.to %></h4> </h3>
                <p> <%= chat.msg %> </p>
                <a href="http://localhost:8080/chats/<%= chat._id %>"><button>Edit</button></a>
            </div>

        <%} %>
    </div>
    
</body>
</html>